{
  "agents": {
    "nexlink": "dev-nexlink",
    "grw": "dev-grw",
    "ptopr": "main",
    "default": "dev-nexlink"
  },
  "schedule": "0 22 * * *",
  "email": {
    "to": "alex.bogdan@firmade.it",
    "time": "07:00"
  },
  "repos": [
    {
      "path": "~/.openclaw/skills/nexlink",
      "alias": "nexlink",
      "default": true
    },
    {
      "path": "~/.openclaw/skills/github-release-watch",
      "alias": "grw",
      "default": false
    }
  ],
  "missions_dir": "missions",
  "logs_dir": "logs",
  "max_missions_per_night": 3,
  "branch_prefix": "night-shift"
}
